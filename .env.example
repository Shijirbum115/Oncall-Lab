# Supabase Configuration
# Copy this file to .env and fill in your actual credentials
# NEVER commit the .env file to git!

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Firebase Configuration (Optional - already in config files)
# These are already configured in google-services.json and GoogleService-Info.plist
# FIREBASE_API_KEY=your-firebase-api-key
# FIREBASE_PROJECT_ID=your-firebase-project-id

# QPAY Configuration
# QPay credentials live ONLY in Supabase Edge Function secrets, not in this file.
# Set them with:  supabase secrets set QPAY_USERNAME=... QPAY_PASSWORD=... \
#   QPAY_INVOICE_CODE=... QPAY_API_URL=https://merchant.qpay.mn/v2
